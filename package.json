{
  "name": "shelter-sessions",
  "version": "1.0.0",
  "description": "A mobile learning app designed for offline environments. Learn something new in 15 minutes.",
  "main": "index.ts",
  "author": "Shelter Sessions Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/shelter-sessions.git"
  },
  "keywords": [
    "react-native",
    "expo",
    "education",
    "offline-first",
    "learning",
    "mobile",
    "android"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "generate-manifest": "node scripts/generate-manifest.js",
    "validate-build": "bash scripts/validate-build.sh",
    "prebuild": "npm run validate-build",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.0",
    "expo-constants": "~18.0.0",
    "expo-font": "~14.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@react-native-community/eslint-config": "^3.2.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^55.0.11",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-native": "^4.1.0",
    "husky": "9.1.7",
    "jest": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "prettier": "^3.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": false,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
